# Normaliza line-endings: LF en repo, lo que toque en cada SO al hacer checkout.
# Evita el ruido CRLF↔LF tras subidas desde Windows.
* text=auto eol=lf

# Binarios — nunca tocar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.jar   binary
*.class binary
