# Base de datos (Aiven - MySQL cloud)
# Los datos de conexión se encuentran en el panel de Aiven → tu servicio MySQL → Connection information
spring.datasource.url=jdbc:mysql://<AIVEN_HOST>:<AIVEN_PORT>/defaultdb?useSSL=true&requireSSL=true
spring.datasource.username=avnadmin
spring.datasource.password=TU_PASSWORD_AIVEN
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA / Hibernate
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true

# Puerto del servidor
server.port=8080

# JWT
# La clave secreta debe tener mínimo 32 caracteres (se usa para firmar los tokens con HMAC-SHA512)
# Genera una clave segura y no la compartas ni la subas a GitHub
jwt.secret=TU_CLAVE_SECRETA_MINIMO_32_CARACTERES
# Tiempo de expiración del access token en milisegundos (3600000 = 1 hora)
# Los refresh tokens duran más y se renuevan automáticamente desde el frontend
jwt.expiration-ms=3600000

# Refresh tokens
# Días de validez del refresh token (se renueva en cada login)
refresh-token.expiration-days=7

# Email (Gmail con App Password)
# En Gmail: Ajustes → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=tu_email@gmail.com
spring.mail.password=xxxx_xxxx_xxxx_xxxx
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# URL del frontend (se usa en el enlace del email de verificación)
# Desarrollo: http://localhost:5173  |  Producción: https://zentimes.es
app.url=http://localhost:5173
