# Base de datos (Aiven - MySQL cloud)
# Los datos de conexión se encuentran en el panel de Aiven → tu servicio MySQL → Connection information
spring.datasource.url=jdbc:mysql://<AIVEN_HOST>:<AIVEN_PORT>/defaultdb?useSSL=true&requireSSL=true
spring.datasource.username=avnadmin
spring.datasource.password=TU_PASSWORD_AIVEN
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA / Hibernate
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true

# Puerto del servidor
server.port=8080

# JWT
# La clave secreta debe tener mínimo 32 caracteres (se usa para firmar los tokens con HMAC-SHA512)
# Genera una clave segura y no la compartas ni la subas a GitHub
jwt.secret=TU_CLAVE_SECRETA_MINIMO_32_CARACTERES
# Tiempo de expiración del token en milisegundos (86400000 = 24 horas)
jwt.expiration-ms=86400000
