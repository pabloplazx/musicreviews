# ============================================================
# .env.example — Plantilla de variables de entorno
# ============================================================
# Copia este archivo a .env y rellena los valores reales.
# El archivo .env está gitignored y NO debe versionarse jamás.
#
# Uso:
#   1. cp .env.example .env
#   2. Edita .env con tus credenciales
#   3. docker compose up --build
# ============================================================


# --- MySQL (contenedor local del docker-compose) ---
# Estos valores se aplican al contenedor mysql al arrancar y al backend al conectar
MYSQL_ROOT_PASSWORD=rootchangeme
MYSQL_DATABASE=musicreviews
MYSQL_USER=musicreviews
MYSQL_PASSWORD=changeme


# --- Backend Spring Boot ---
# JWT secret: cadena aleatoria de al menos 32 caracteres
# Generar con: openssl rand -base64 48   (Git Bash)
JWT_SECRET=cambia-esto-por-una-cadena-aleatoria-de-min-32-caracteres
JWT_EXPIRATION_MS=86400000

# Credenciales de APIs externas (Spotify y Last.fm)
# Spotify: https://developer.spotify.com/dashboard
# Last.fm: https://www.last.fm/api/accounts
SPOTIFY_CLIENT_ID=tu-spotify-client-id
SPOTIFY_CLIENT_SECRET=tu-spotify-client-secret
LASTFM_API_KEY=tu-lastfm-api-key


# --- Aiven (solo necesario para regenerar el seed con dump-aiven.sh) ---
# Si no vas a regenerar el dump, puedes dejar estos valores como placeholder.
# El stack Docker funciona sin estas variables — solo las necesita el script de dump.
AIVEN_HOST=tu-instancia.aivencloud.com
AIVEN_PORT=11527
AIVEN_USER=avnadmin
AIVEN_PASSWORD=tu-aiven-password
AIVEN_DATABASE=defaultdb
